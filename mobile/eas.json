{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_APP_BASE_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": false },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APP_BASE_URL": "https://whatsapp-cs.vercel.app"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_APP_BASE_URL": "https://whatsapp-cs.vercel.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "daleelhksa@gmail.com",
        "ascAppId": "6762078573"
      }
    }
  }
}