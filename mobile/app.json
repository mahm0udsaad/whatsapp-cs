{
  "expo": {
    "name": "Agent Console",
    "slug": "whatsapp-cs-agent",
    "version": "0.3.0",
    "orientation": "portrait",
    "scheme": "whatsapp-cs-agent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.nehgz.nehgzbot",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.whatsappcs.agentconsole",
      "adaptiveIcon": {
        "backgroundColor": "#25D366"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#25D366",
          "defaultChannel": "escalations"
        }
      ]
    ],
    "extra": {
      "i18n": {
        "localeLang": "ar"
      },
      "notifications": {
        "ios": {
          "categories": [
            {
              "identifier": "escalations",
              "actions": [
                {
                  "identifier": "view",
                  "buttonTitle": "عرض"
                }
              ]
            }
          ]
        },
        "android": {
          "channels": [
            {
              "id": "escalations",
              "name": "Escalations",
              "importance": "max",
              "sound": "default",
              "vibrationPattern": [
                0,
                250,
                250,
                250
              ],
              "lockscreenVisibility": "public"
            }
          ]
        }
      },
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a7b7daaf-c9db-427e-9e3b-fc032fb045ef"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "mahm0udsaad",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a7b7daaf-c9db-427e-9e3b-fc032fb045ef"
    }
  }
}
