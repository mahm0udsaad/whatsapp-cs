{
  "expo": {
    "name": "Nehgz Bot",
    "slug": "whatsapp-cs-agent",
    "version": "1.0.3",
    "orientation": "portrait",
    "scheme": "whatsapp-cs-agent",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "ios": {
      "bundleIdentifier": "com.nehgz.nehgzbot",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "نحتاج إذنك للوصول إلى صورك حتى تتمكن من إرفاق الصور في محادثات الواتساب مع عملائك وفي حملاتك التسويقية."
      }
    },
    "android": {
      "package": "com.nehgz.nehgzbot",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1e3a8a"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#25D366",
          "defaultChannel": "escalations"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج إذنك للوصول إلى صورك حتى تتمكن من إرفاق الصور في محادثات الواتساب مع عملائك.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "expo-web-browser",
      "expo-video"
    ],
    "extra": {
      "i18n": {
        "localeLang": "ar"
      },
      "notifications": {
        "ios": {
          "categories": [
            {
              "identifier": "escalations",
              "actions": [
                {
                  "identifier": "view",
                  "buttonTitle": "عرض"
                }
              ]
            }
          ]
        },
        "android": {
          "channels": [
            {
              "id": "escalations",
              "name": "Escalations",
              "importance": "max",
              "sound": "default",
              "vibrationPattern": [
                0,
                250,
                250,
                250
              ],
              "lockscreenVisibility": "public"
            }
          ]
        }
      },
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a7b7daaf-c9db-427e-9e3b-fc032fb045ef"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "mahm0udsaad",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a7b7daaf-c9db-427e-9e3b-fc032fb045ef"
    }
  }
}
